{
  "name": "explorer-enhanced",
  "displayName": "Explorer Enhanced",
  "description": "Folder-first navigation with a Files webview (table: name, modified, size; instant name filter; codicon toolbar).",
  "icon": "images/explorer-enhanced.png",
  "version": "1.0.0",
  "publisher": "Vincent1024",
  "repository": {
    "type": "git",
    "url": "https://github.com/Vince1024/Explorer-Enhanced-For-VsCode.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:explorer-enhanced.folderTree",
    "onView:explorer-enhanced.filePane",
    "onCommand:explorer-enhanced.focus"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "explorer-enhanced",
          "title": "Explorer Enhanced",
          "icon": "$(folder)"
        }
      ]
    },
    "views": {
      "explorer-enhanced": [
        {
          "id": "explorer-enhanced.folderTree",
          "name": "Folders"
        },
        {
          "type": "webview",
          "id": "explorer-enhanced.filePane",
          "name": "Files"
        }
      ]
    },
    "configuration": [
      {
        "title": "Explorer Enhanced",
        "order": 0,
        "properties": {
          "explorer-enhanced.focusOnStart": {
            "type": "boolean",
            "default": false,
            "markdownDescription": "When enabled, **Explorer Enhanced** automatically receives focus each time a window opens or reloads. This does **not** replicate a native VS Code \"restore last Activity Bar view\" feature \u2014 it unconditionally switches the sidebar to Explorer Enhanced."
          }
        }
      },
      {
        "title": "Folders",
        "order": 1,
        "properties": {
          "explorer-enhanced.folders.folderExpandInteraction": {
            "type": "string",
            "default": "inherit",
            "enum": [
              "inherit",
              "doubleClick",
              "singleClick"
            ],
            "enumDescriptions": [
              "Do not change `workbench.tree.expandMode` (use your existing VS Code / workspace setting).",
              "Single click on a folder row only selects it and updates **Files**; expand/collapse uses the twistie (>) or a double-click on the folder name. Sets `workbench.tree.expandMode` to `doubleClick` for this workspace (affects other sidebar trees too).",
              "Single click on a folder row expands or collapses (VS Code default for trees)."
            ],
            "markdownDescription": "How folder rows expand in the **Folders** tree. `doubleClick` matches typical Explorer behavior: **chevron (>)** or **double-click** on the name toggles; **single click** only selects.\n\nImplemented via the built-in setting `workbench.tree.expandMode` at **workspace** scope when you choose `doubleClick` or `singleClick`, so **Built-in Explorer, SCM, and other trees** in the same workspace follow the same rule.\n\n**Files** shown in the Folders tree still **open on single click** (they use `vscode.open`; VS Code ignores expand mode for items that have a `command`)."
          }
        }
      },
      {
        "title": "Files",
        "order": 2,
        "properties": {
          "explorer-enhanced.files.dateTimeFormat": {
            "order": 0,
            "type": "string",
            "default": "locale",
            "enum": [
              "locale",
              "localeDate",
              "localeTime",
              "iso",
              "relative",
              "custom"
            ],
            "enumDescriptions": [
              "Full locale date and time (default, same as before).",
              "Locale date only.",
              "Locale time only.",
              "ISO 8601 (UTC).",
              "Relative for recent times (e.g. \u201c5 min ago\u201d), otherwise a short locale date.",
              "Pattern from **Files: Date Time Custom Pattern** (e.g. DD-MM-YYYY HH:mm:ss)."
            ],
            "markdownDescription": "How the **Modified** column is shown in the **Files** view."
          },
          "explorer-enhanced.files.dateTimeCustomPattern": {
            "order": 1,
            "type": "string",
            "default": "DD-MM-YYYY HH:mm:ss",
            "markdownDescription": "Used when **Files: Date Time Format** is `custom`. Tokens: `YYYY`/`yyyy`, `YY`/`yy`, `MM` (month, 2 digits), `DD` (day), `HH` (24h), `mm` (minutes, **lowercase**), `ss`, `SSS` (milliseconds). Other characters (spaces, `-`, `:`, \u2026) are copied as-is. Values use the local timezone."
          },
          "explorer-enhanced.files.followLnkLinks": {
            "order": 2,
            "type": "boolean",
            "default": false,
            "markdownDescription": "When enabled on **Windows**, opening a `.lnk` shortcut from **Files** or the context menu opens the **shortcut target** (via PowerShell / WScript.Shell) instead of the binary `.lnk` file. If resolution fails, the `.lnk` is opened as usual. No effect on macOS or Linux."
          }
        }
      }
    ],
    "commands": [
      {
        "command": "explorer-enhanced.focus",
        "title": "Explorer Enhanced: Show",
        "category": "Explorer Enhanced"
      },
      {
        "command": "explorer-enhanced.showFoldersInList",
        "title": "Show subfolders in Files list",
        "category": "Explorer Enhanced",
        "icon": "$(folder)"
      },
      {
        "command": "explorer-enhanced.hideFoldersInList",
        "title": "Hide subfolders in Files list",
        "category": "Explorer Enhanced",
        "icon": "$(circle-slash)"
      },
      {
        "command": "explorer-enhanced.viewLayout.list",
        "title": "List",
        "category": "Explorer Enhanced",
        "icon": "$(list-flat)"
      },
      {
        "command": "explorer-enhanced.viewLayout.detail",
        "title": "Details",
        "category": "Explorer Enhanced",
        "icon": "$(list-tree)"
      },
      {
        "command": "explorer-enhanced.viewLayout.icons",
        "title": "Icons",
        "category": "Explorer Enhanced",
        "icon": "$(gallery)"
      },
      {
        "command": "explorer-enhanced.folders.showFilesInTree",
        "title": "Show files in Folders tree",
        "category": "Explorer Enhanced",
        "icon": "$(folder)"
      },
      {
        "command": "explorer-enhanced.folders.hideFilesInTree",
        "title": "Hide files in Folders tree (folders only)",
        "category": "Explorer Enhanced",
        "icon": "$(file)"
      },
      {
        "command": "explorer-enhanced.ctx.folder.newFile",
        "title": "New File..."
      },
      {
        "command": "explorer-enhanced.ctx.folder.newFolder",
        "title": "New Folder..."
      },
      {
        "command": "explorer-enhanced.ctx.folder.refresh",
        "title": "Refresh"
      },
      {
        "command": "explorer-enhanced.ctx.folder.revealInExplorer",
        "title": "Reveal in Explorer View"
      },
      {
        "command": "explorer-enhanced.ctx.folder.revealInOs.win",
        "title": "Reveal in File Explorer"
      },
      {
        "command": "explorer-enhanced.ctx.folder.revealInOs.macos",
        "title": "Reveal in Finder"
      },
      {
        "command": "explorer-enhanced.ctx.folder.revealInOs.linux",
        "title": "Open Containing Folder"
      },
      {
        "command": "explorer-enhanced.ctx.folder.revealInOs.other",
        "title": "Reveal in OS"
      },
      {
        "command": "explorer-enhanced.ctx.folder.openInTerminal",
        "title": "Open in Integrated Terminal"
      },
      {
        "command": "explorer-enhanced.ctx.folder.copyPath",
        "title": "Copy Path"
      },
      {
        "command": "explorer-enhanced.ctx.folder.copyRelativePath",
        "title": "Copy Relative Path"
      },
      {
        "command": "explorer-enhanced.ctx.folder.rename",
        "title": "Rename..."
      },
      {
        "command": "explorer-enhanced.ctx.folder.delete",
        "title": "Delete"
      },
      {
        "command": "explorer-enhanced.ctx.folder.moveWorkspaceRootUp",
        "title": "Move Workspace Folder Up",
        "category": "Explorer Enhanced",
        "icon": "$(arrow-up)"
      },
      {
        "command": "explorer-enhanced.ctx.folder.moveWorkspaceRootDown",
        "title": "Move Workspace Folder Down",
        "category": "Explorer Enhanced",
        "icon": "$(arrow-down)"
      },
      {
        "command": "explorer-enhanced.filesPane.renameSelection",
        "title": "Rename Files pane selection (keyboard)",
        "category": "Explorer Enhanced"
      },
      {
        "command": "explorer-enhanced.filesPane.deleteSelection",
        "title": "Delete Files pane selection (keyboard)",
        "category": "Explorer Enhanced"
      }
    ],
    "keybindings": [
      {
        "command": "explorer-enhanced.filesPane.renameSelection",
        "key": "f2",
        "when": "editorTextFocus && explorer-enhanced.filesPaneEditorKbActive && resourceScheme == 'file'"
      },
      {
        "command": "explorer-enhanced.filesPane.deleteSelection",
        "key": "delete",
        "when": "editorTextFocus && explorer-enhanced.filesPaneEditorKbActive && resourceScheme == 'file'"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "explorer-enhanced.ctx.folder.newFile",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.ctx.folder.newFolder",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.ctx.folder.refresh",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.ctx.folder.revealInExplorer",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.ctx.folder.revealInOs.win",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.ctx.folder.revealInOs.macos",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.ctx.folder.revealInOs.linux",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.ctx.folder.revealInOs.other",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.ctx.folder.openInTerminal",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.ctx.folder.copyPath",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.ctx.folder.copyRelativePath",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.ctx.folder.rename",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.ctx.folder.delete",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.showFoldersInList",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.hideFoldersInList",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.viewLayout.list",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.viewLayout.detail",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.viewLayout.icons",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.folders.showFilesInTree",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.folders.hideFilesInTree",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.ctx.folder.moveWorkspaceRootUp",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.ctx.folder.moveWorkspaceRootDown",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.filesPane.renameSelection",
          "when": "false"
        },
        {
          "command": "explorer-enhanced.filesPane.deleteSelection",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "explorer-enhanced.folders.showFilesInTree",
          "when": "view == explorer-enhanced.folderTree && !explorer-enhanced.showFilesInTree",
          "group": "navigation@1"
        },
        {
          "command": "explorer-enhanced.folders.hideFilesInTree",
          "when": "view == explorer-enhanced.folderTree && explorer-enhanced.showFilesInTree",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "explorer-enhanced.ctx.folder.newFile",
          "when": "view == explorer-enhanced.folderTree && viewItem == explorer-enhanced.folder",
          "group": "navigation@1"
        },
        {
          "command": "explorer-enhanced.ctx.folder.newFolder",
          "when": "view == explorer-enhanced.folderTree && viewItem == explorer-enhanced.folder",
          "group": "navigation@2"
        },
        {
          "command": "explorer-enhanced.ctx.folder.refresh",
          "when": "view == explorer-enhanced.folderTree && viewItem == explorer-enhanced.folder",
          "group": "navigation@10"
        },
        {
          "command": "explorer-enhanced.ctx.folder.moveWorkspaceRootUp",
          "when": "view == explorer-enhanced.folderTree && viewItem == explorer-enhanced.folder && explorer-enhanced.multiRootWorkspace",
          "group": "8_workspace@1"
        },
        {
          "command": "explorer-enhanced.ctx.folder.moveWorkspaceRootDown",
          "when": "view == explorer-enhanced.folderTree && viewItem == explorer-enhanced.folder && explorer-enhanced.multiRootWorkspace",
          "group": "8_workspace@2"
        },
        {
          "command": "explorer-enhanced.ctx.folder.revealInExplorer",
          "when": "view == explorer-enhanced.folderTree && (viewItem == explorer-enhanced.folder || viewItem == explorer-enhanced.treeFile)",
          "group": "3_open@1"
        },
        {
          "command": "explorer-enhanced.ctx.folder.revealInOs.win",
          "when": "view == explorer-enhanced.folderTree && (viewItem == explorer-enhanced.folder || viewItem == explorer-enhanced.treeFile) && isWindows",
          "group": "3_open@2"
        },
        {
          "command": "explorer-enhanced.ctx.folder.revealInOs.macos",
          "when": "view == explorer-enhanced.folderTree && (viewItem == explorer-enhanced.folder || viewItem == explorer-enhanced.treeFile) && isMac",
          "group": "3_open@2"
        },
        {
          "command": "explorer-enhanced.ctx.folder.revealInOs.linux",
          "when": "view == explorer-enhanced.folderTree && (viewItem == explorer-enhanced.folder || viewItem == explorer-enhanced.treeFile) && isLinux",
          "group": "3_open@2"
        },
        {
          "command": "explorer-enhanced.ctx.folder.revealInOs.other",
          "when": "view == explorer-enhanced.folderTree && (viewItem == explorer-enhanced.folder || viewItem == explorer-enhanced.treeFile) && !isWindows && !isMac && !isLinux",
          "group": "3_open@2"
        },
        {
          "command": "explorer-enhanced.ctx.folder.openInTerminal",
          "when": "view == explorer-enhanced.folderTree && (viewItem == explorer-enhanced.folder || viewItem == explorer-enhanced.treeFile)",
          "group": "3_open@5"
        },
        {
          "command": "explorer-enhanced.ctx.folder.copyPath",
          "when": "view == explorer-enhanced.folderTree && (viewItem == explorer-enhanced.folder || viewItem == explorer-enhanced.treeFile)",
          "group": "5_cutcopypaste@1"
        },
        {
          "command": "explorer-enhanced.ctx.folder.copyRelativePath",
          "when": "view == explorer-enhanced.folderTree && (viewItem == explorer-enhanced.folder || viewItem == explorer-enhanced.treeFile)",
          "group": "5_cutcopypaste@2"
        },
        {
          "command": "explorer-enhanced.ctx.folder.rename",
          "when": "view == explorer-enhanced.folderTree && (viewItem == explorer-enhanced.folder || viewItem == explorer-enhanced.treeFile)",
          "group": "7_modification@1"
        },
        {
          "command": "explorer-enhanced.ctx.folder.delete",
          "when": "view == explorer-enhanced.folderTree && (viewItem == explorer-enhanced.folder || viewItem == explorer-enhanced.treeFile)",
          "group": "7_modification@2"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.18.0"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45"
  }
}
